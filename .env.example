# Bare-metal dev: `app/config.py` auto-loads `.env` from the repo root via
# python-dotenv. A real shell env (CI, systemd `EnvironmentFile=`, Docker
# Compose `env_file:`) overrides anything in this file.
#
# Docker: `docker-compose.yml` reads the same `.env` for ${DOMAIN},
# ${ADMIN_SLUG}, ${ADMIN_PASSWORD}, the ${SMTP_*} vars, and ${BORDERLINE_LOG_PATH}.
#
# Empty values are fine — every var below falls back to a sensible default.

# --- Admin gate ---------------------------------------
# Both required for /admin/{slug}/ to be reachable. Empty → 404.
ADMIN_SLUG=
ADMIN_PASSWORD=

# --- Storage -------------------------------------------------------------
# DATA_ROOT defaults to <repo>/data for dev. Production: e.g. /var/lib/reframe
DATA_ROOT=
STORAGE_BACKEND=local

# --- Validation thresholds -----------------------------------------------
# Defaults: 800 / 100 / 8
MIN_RESOLUTION_LONG_EDGE=
BLUR_LAPLACIAN_THRESHOLD=
FEATURE_MATCH_MIN_MATCHES=

# Where the borderline-match logger writes. Empty → stdout via the standard
# Python logger. Example: /var/log/reframe/borderline.log
BORDERLINE_LOG_PATH=

# --- Operational toggles (empty = default) -------------------------------
# Community submission form on /host. Empty/false → form hidden and /host 404s.
SUBMISSIONS_ENABLED=true
# Radius (km) for the "Nearby stations" section on each station page. Empty → 50.
NEARBY_RADIUS_KM=


# --- Submission-form mailer (all optional; form silently no-ops if unset) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_USE_TLS=true
SMTP_FROM_ADDRESS=
SMTP_RECIPIENT=
SMTP_PASSWORD=

# --- Docker / Caddy ------------------------------------------------------
# Used by docker-compose.yml + Caddyfile only. Omit for a local Docker run
# (defaults to localhost). Production: your real domain.
DOMAIN=
